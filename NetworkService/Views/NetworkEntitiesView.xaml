<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Add sensor panel -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="12" Margin="0,0,0,10" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="Add Sensor" Style="{StaticResource SectionHeaderStyle}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Type:" Style="{StaticResource LabelStyle}" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding AvailableTypes}"
                              SelectedItem="{Binding SelectedTypeToAdd}"
                              DisplayMemberPath="Name"
                              Width="160"
                              ToolTip="Select the type of sensor to add"/>
                    <Button Content="Add Sensor"
                            Command="{Binding AddSensorCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="12,0,0,0"
                            ToolTip="Add a new sensor of the selected type"/>
                </StackPanel>
                <TextBlock Text="{Binding TypeError}" Style="{StaticResource ErrorStyle}"/>
            </StackPanel>
        </Border>

        <!-- Search panel -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="12" Margin="0,0,0,10" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="Search" Style="{StaticResource SectionHeaderStyle}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <RadioButton Content="By Name" IsChecked="{Binding SearchByName}"
                                 Foreground="{StaticResource TextBrush}" Margin="0,0,15,0"
                                 ToolTip="Search sensors by name"/>
                    <RadioButton Content="By Type" IsChecked="{Binding SearchByType}"
                                 Foreground="{StaticResource TextBrush}"
                                 ToolTip="Search sensors by type"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" Style="{StaticResource InputStyle}"
                             ToolTip="Enter search term"/>
                    <Button Content="Search" Command="{Binding SearchCommand}"
                            Style="{StaticResource ActionButtonStyle}" Margin="8,0,0,0"
                            ToolTip="Apply search"/>
                    <Button Content="Clear" Command="{Binding ClearSearchCommand}"
                            Style="{StaticResource NavButtonStyle}" Margin="6,0,0,0"
                            ToolTip="Clear search and show all sensors"/>
                    <Button Content="Save Search" Command="{Binding SaveSearchCommand}"
                            Style="{StaticResource NavButtonStyle}" Margin="6,0,0,0"
                            ToolTip="Save this search for later use"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Saved searches:" Style="{StaticResource LabelStyle}" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding SavedSearches}"
                              SelectedItem="{Binding SelectedSavedSearch}"
                              Width="200" Padding="6,4"
                              Background="#0D1117" Foreground="{StaticResource TextBrush}"
                              BorderBrush="{StaticResource BorderBrush}"
                              ToolTip="Select a saved search to apply it"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Delete button -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Delete Selected"
                    Command="{Binding DeleteSensorCommand}"
                    Style="{StaticResource DangerButtonStyle}"
                    ToolTip="Delete the selected sensor from the list"/>
        </StackPanel>

        <!-- Sensors table -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding FilteredSensors}"
                  SelectedItem="{Binding SelectedSensor}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserDeleteRows="False"
                  CanUserAddRows="False"
                  Background="{StaticResource PanelBrush}"
                  Foreground="{StaticResource TextBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  RowBackground="#1E2A45"
                  AlternatingRowBackground="#16213E"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="8,6"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type.Name}" Width="130"/>
                <DataGridTextColumn Header="Last Value (°C)" Binding="{Binding LastMeasuredValue, StringFormat='{}{0:F1}'}" Width="130"/>
                <DataGridTemplateColumn Header="Status" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OK"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValueValid}" Value="False">
                                                <Setter Property="Text" Value="OUT OF RANGE"/>
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
