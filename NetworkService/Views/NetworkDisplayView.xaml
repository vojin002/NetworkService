<UserControl x:Class="NetworkService.Views.NetworkDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="AutoArrangeBtn"
                    Content="Auto Arrange All"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="AutoArrangeBtn_Click"
                    ToolTip="Automatically place all sensors on the grid"/>
            <Button x:Name="ConnectBtn"
                    Content="Connect Sensors"
                    Style="{StaticResource NavButtonStyle}"
                    Margin="8,0,0,0"
                    Click="ConnectBtn_Click"
                    ToolTip="Click to enter connect mode, then click two sensors to draw a line"/>
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" Margin="0,0,8,0" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="Sensors" Style="{StaticResource SectionHeaderStyle}"
                           Margin="8,8,8,4" FontSize="13"
                           TextAlignment="Center"/>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Margin="8,0,8,4"/>
                <TreeView x:Name="SensorTreeView"
                          ItemsSource="{Binding SensorGroups}"
                          Background="Transparent"
                          Foreground="{StaticResource TextBrush}"
                          BorderThickness="0"
                          PreviewMouseLeftButtonDown="TreeView_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="TreeView_PreviewMouseMove">
                    <TreeView.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E3F2FD"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1A202C"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E3F2FD"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1A202C"/>
                    </TreeView.Resources>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Sensors}">
                            <TextBlock Text="{Binding TypeName}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="12"/>
                            <HierarchicalDataTemplate.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2" Cursor="Hand">
                                        <Ellipse Width="7" Height="7"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,5,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsValueValid}" Value="False">
                                                            <Setter Property="Fill" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <Image Source="{Binding Type.ImagePath}" Width="16" Height="16"
                                               Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   ToolTip="Drag to place on the grid"/>
                                    </StackPanel>
                                </DataTemplate>
                            </HierarchicalDataTemplate.ItemTemplate>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="4">
            <Grid>
                <UniformGrid x:Name="CanvasGrid" Rows="3" Columns="4"
                             AllowDrop="True"
                             DragOver="CanvasGrid_DragOver"
                             Drop="CanvasGrid_Drop"/>
                <Canvas x:Name="LinesCanvas" IsHitTestVisible="False"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
