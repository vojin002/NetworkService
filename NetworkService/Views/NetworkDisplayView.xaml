<UserControl x:Class="NetworkService.Views.NetworkDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="AutoArrangeBtn"
                    Content="Auto Arrange All"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="AutoArrangeBtn_Click"
                    ToolTip="Automatically place all sensors on the grid"/>
            <Button x:Name="ConnectBtn"
                    Content="Connect Sensors"
                    Style="{StaticResource NavButtonStyle}"
                    Margin="8,0,0,0"
                    Click="ConnectBtn_Click"
                    ToolTip="Click to enter connect mode, then click two sensors to draw a line"/>
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" Margin="0,0,8,0" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="Sensors" Style="{StaticResource SectionHeaderStyle}"
                           Margin="8,8,8,4" FontSize="13"/>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Margin="8,0,8,4"/>
                <TreeView x:Name="SensorTreeView"
                          ItemsSource="{Binding SensorsInTreeView}"
                          Background="Transparent"
                          Foreground="{StaticResource TextBrush}"
                          BorderThickness="0"
                          PreviewMouseLeftButtonDown="TreeView_PreviewMouseLeftButtonDown">
                    <TreeView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Ellipse Width="7" Height="7"
                                         Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           ToolTip="Drag to place on the grid"/>
                            </StackPanel>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="4">
            <Grid>
                <UniformGrid x:Name="CanvasGrid" Rows="3" Columns="4"
                             AllowDrop="True"
                             DragOver="CanvasGrid_DragOver"
                             Drop="CanvasGrid_Drop"/>
                <Canvas x:Name="LinesCanvas" IsHitTestVisible="False"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
